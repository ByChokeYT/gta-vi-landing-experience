---
import ViceCityScenery from "@/assets/vice-city-scenery.png"
import HeroKeyBackground from "@/assets/hero-key-background.webp"
import ViceCityNight from "@/assets/vice-city-night.png"
---

<!-- Section: Gallery -->
<section id="galeria" class="scroll-mt-28 space-y-16 py-12">
  <div class="text-center max-w-2xl mx-auto space-y-4 reveal-on-scroll">
    <span class="text-xs font-bold tracking-widest text-pink-500 uppercase bg-pink-500/10 px-3 py-1 rounded-full border border-pink-500/20">
      Galería de Imágenes
    </span>
    <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight">CAPTURAS OFICIALES</h2>
    <p class="text-zinc-400 font-narrow text-base md:text-lg">
      Echa un vistazo al impresionante apartado visual y la atmósfera vibrante de Leonida en las capturas oficiales.
    </p>
  </div>
  
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal-section">
    <!-- Item 1 -->
    <div
      class="gallery-item reveal-item group relative aspect-[16/9] overflow-hidden rounded-2xl border border-zinc-800 cursor-pointer bg-zinc-950"
      data-src={ViceCityScenery.src}
    >
      <img src={ViceCityScenery.src} alt="Atardecer en Leonida" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
      <div class="absolute inset-0 bg-zinc-950/45 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-all duration-400 flex flex-col justify-between p-5 z-20">
        <div class="flex justify-end transform -translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
          <div class="bg-pink-500/10 border border-pink-500/30 text-white rounded-full p-2.5 backdrop-blur-md shadow-lg shadow-pink-500/5 hover:scale-110 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-4 text-pink-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
            </svg>
          </div>
        </div>
        <div class="transform translate-y-3 group-hover:translate-y-0 transition-all duration-500 space-y-0.5">
          <span class="text-[9px] font-bold text-pink-400 uppercase tracking-widest">Captura Oficial</span>
          <h4 class="text-base font-extrabold text-white tracking-wide">Atardecer en Leonida</h4>
        </div>
      </div>
    </div>
    
    <!-- Item 2 -->
    <div
      class="gallery-item reveal-item group relative aspect-[16/9] overflow-hidden rounded-2xl border border-zinc-800 cursor-pointer bg-zinc-950"
      data-src={HeroKeyBackground.src}
    >
      <img src={HeroKeyBackground.src} alt="Protagonistas de GTA VI" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
      <div class="absolute inset-0 bg-zinc-950/45 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-all duration-400 flex flex-col justify-between p-5 z-20">
        <div class="flex justify-end transform -translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
          <div class="bg-pink-500/10 border border-pink-500/30 text-white rounded-full p-2.5 backdrop-blur-md shadow-lg shadow-pink-500/5 hover:scale-110 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-4 text-pink-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
            </svg>
          </div>
        </div>
        <div class="transform translate-y-3 group-hover:translate-y-0 transition-all duration-500 space-y-0.5">
          <span class="text-[9px] font-bold text-pink-400 uppercase tracking-widest">Captura Oficial</span>
          <h4 class="text-base font-extrabold text-white tracking-wide">Protagonistas de GTA VI</h4>
        </div>
      </div>
    </div>
    
    <!-- Item 3 -->
    <div
      class="gallery-item reveal-item group relative aspect-[16/9] overflow-hidden rounded-2xl border border-zinc-800 cursor-pointer bg-zinc-950"
      data-src={ViceCityNight.src}
    >
      <img src={ViceCityNight.src} alt="Luces de Neón por la noche" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
      <div class="absolute inset-0 bg-zinc-950/45 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-all duration-400 flex flex-col justify-between p-5 z-20">
        <div class="flex justify-end transform -translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
          <div class="bg-pink-500/10 border border-pink-500/30 text-white rounded-full p-2.5 backdrop-blur-md shadow-lg shadow-pink-500/5 hover:scale-110 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-4 text-pink-400">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
            </svg>
          </div>
        </div>
        <div class="transform translate-y-3 group-hover:translate-y-0 transition-all duration-500 space-y-0.5">
          <span class="text-[9px] font-bold text-pink-400 uppercase tracking-widest">Captura Oficial</span>
          <h4 class="text-base font-extrabold text-white tracking-wide">Luces de Neón por la noche</h4>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Lightbox Gallery Modal -->
<div
  id="lightbox"
  class="fixed inset-0 z-100 flex items-center justify-center bg-black/95 opacity-0 pointer-events-none transition-opacity duration-300"
>
  <button
    id="close-lightbox"
    class="absolute top-4 right-4 text-white hover:text-pink-500 bg-black/40 hover:bg-black/80 backdrop-blur rounded-full p-2 cursor-pointer"
    aria-label="Cerrar galería"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <img id="lightbox-img" src="" alt="Gallery Image" class="max-w-[90%] max-h-[85vh] object-contain rounded-lg border border-zinc-800 shadow-2xl" />
</div>

<script>
  // Lightbox Gallery Logic
  const galleryItems = document.querySelectorAll(".gallery-item");
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const closeLightbox = document.getElementById("close-lightbox");

  galleryItems.forEach((item) => {
    item.addEventListener("click", () => {
      const src = item.getAttribute("data-src");
      if (src && lightboxImg && lightbox) {
        lightboxImg.src = src;
        lightbox.classList.remove("opacity-0", "pointer-events-none");
        document.body.style.overflow = "hidden";
      }
    });
  });

  function closeLightboxFunc() {
    if (lightbox) {
      lightbox.classList.add("opacity-0", "pointer-events-none");
      document.body.style.overflow = "";
    }
  }

  closeLightbox?.addEventListener("click", closeLightboxFunc);
  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) {
      closeLightboxFunc();
    }
  });
</script>
