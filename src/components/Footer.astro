---
import LogoVI from "@/assets/logo-vi.svg"
---

<!-- Page Footer -->
<footer class="border-t border-zinc-900/80 pt-16 pb-12 mt-20 text-center space-y-6 text-xs text-zinc-500">
  <div class="flex justify-center items-center gap-6">
    <LogoVI class="h-8 w-auto text-zinc-600 hover:text-white transition-colors cursor-pointer" />
  </div>
  <p class="max-w-md mx-auto leading-relaxed font-narrow">
    © {new Date().getFullYear()} Rockstar Games, Inc. Grand Theft Auto, GTA VI y todos los logotipos relacionados son marcas comerciales de Take-Two Interactive Software. Esta es una landing page tributo.
  </p>
  <div class="text-zinc-400 font-narrow text-xs md:text-sm flex flex-col sm:flex-row justify-center items-center gap-3 sm:gap-6 py-2 select-none">
    <span>
      Desarrollado con pasión por 
      <a 
        href="https://portafolio-bychoke.netlify.app/" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="text-pink-500 hover:text-pink-400 font-bold transition-colors underline decoration-pink-500/30 underline-offset-4"
      >
        ByChoke
      </a>
    </span>
    <span class="hidden sm:inline text-zinc-800">|</span>
    <a 
      href="https://buymeacoffee.com/choque151jr" 
      target="_blank" 
      rel="noopener noreferrer" 
      class="inline-flex items-center gap-1.5 text-orange-400 hover:text-orange-300 font-bold transition-colors bg-orange-500/10 px-3.5 py-1.5 rounded-full border border-orange-500/20 hover:scale-105"
    >
      ☕ ¡Invítame un café!
    </a>
  </div>
  <div class="flex justify-center gap-6 text-zinc-600 font-semibold">
    <a href="#" class="hover:text-pink-500 transition-colors">Términos</a>
    <a href="#" class="hover:text-pink-500 transition-colors">Privacidad</a>
    <a href="#" class="hover:text-pink-500 transition-colors">Soporte</a>
  </div>
</footer>
