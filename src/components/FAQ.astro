---
---

<!-- Section: FAQ Accordion -->
<section id="faq" class="scroll-mt-28 space-y-16 py-12 relative z-10">
  <div class="text-center max-w-2xl mx-auto space-y-4 reveal-on-scroll">
    <span class="text-xs font-bold tracking-widest text-orange-500 uppercase bg-orange-500/10 px-3 py-1 rounded-full border border-orange-500/20">
      Información Útil
    </span>
    <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight">PREGUNTAS FRECUENTES</h2>
    <p class="text-zinc-400 font-narrow text-base md:text-lg">
      Resuelve tus dudas sobre el lanzamiento, el mapa, los personajes y el desarrollo de Grand Theft Auto VI.
    </p>
  </div>

  <div class="max-w-3xl mx-auto space-y-4 reveal-section">
    <!-- Item 1 -->
    <div class="faq-item reveal-item border border-zinc-800 bg-zinc-950/40 backdrop-blur rounded-2xl overflow-hidden transition-colors hover:border-pink-500/20">
      <button class="faq-trigger w-full flex items-center justify-between p-6 cursor-pointer text-left focus:outline-none">
        <span class="font-bold text-sm md:text-base text-zinc-100 tracking-wide">¿Cuándo estará disponible oficialmente GTA VI?</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-zinc-400 transform transition-transform duration-300 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div class="faq-content max-h-0 transition-all duration-300 ease-in-out">
        <p class="px-6 pb-6 text-sm text-zinc-400 font-narrow leading-relaxed">
          Rockstar Games ha anunciado que Grand Theft Auto VI se lanzará en otoño de 2025. El reloj de esta landing page tributo está configurado provisionalmente para fines de 2026 a modo de cuenta regresiva estimada hasta confirmación de fechas exactas.
        </p>
      </div>
    </div>

    <!-- Item 2 -->
    <div class="faq-item reveal-item border border-zinc-800 bg-zinc-950/40 backdrop-blur rounded-2xl overflow-hidden transition-colors hover:border-purple-500/20">
      <button class="faq-trigger w-full flex items-center justify-between p-6 cursor-pointer text-left focus:outline-none">
        <span class="font-bold text-sm md:text-base text-zinc-100 tracking-wide">¿En qué plataformas se podrá jugar inicialmente?</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-zinc-400 transform transition-transform duration-300 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div class="faq-content max-h-0 transition-all duration-300 ease-in-out">
        <p class="px-6 pb-6 text-sm text-zinc-400 font-narrow leading-relaxed">
          El juego estará disponible desde el primer día para consolas de última generación: PlayStation 5 y Xbox Series X|S. No se han anunciado versiones nativas para consolas de anterior generación, y se espera que la versión para PC llegue en una fecha posterior.
        </p>
      </div>
    </div>

    <!-- Item 3 -->
    <div class="faq-item reveal-item border border-zinc-800 bg-zinc-950/40 backdrop-blur rounded-2xl overflow-hidden transition-colors hover:border-orange-500/20">
      <button class="faq-trigger w-full flex items-center justify-between p-6 cursor-pointer text-left focus:outline-none">
        <span class="font-bold text-sm md:text-base text-zinc-100 tracking-wide">¿Quiénes son los protagonistas de esta entrega?</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-zinc-400 transform transition-transform duration-300 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div class="faq-content max-h-0 transition-all duration-300 ease-in-out">
        <p class="px-6 pb-6 text-sm text-zinc-400 font-narrow leading-relaxed">
          Por primera vez en la franquicia moderna, controlaremos a una pareja de criminales: Lucía (la primera protagonista femenina jugable) y su compañero Jason. Su historia explorará temas como la lealtad, la confianza y la búsqueda conjunta del golpe definitivo en Vice City.
        </p>
      </div>
    </div>

    <!-- Item 4 -->
    <div class="faq-item reveal-item border border-zinc-800 bg-zinc-950/40 backdrop-blur rounded-2xl overflow-hidden transition-colors hover:border-pink-500/20">
      <button class="faq-trigger w-full flex items-center justify-between p-6 cursor-pointer text-left focus:outline-none">
        <span class="font-bold text-sm md:text-base text-zinc-100 tracking-wide">¿Qué extensión tiene el mapa del juego?</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-zinc-400 transform transition-transform duration-300 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div class="faq-content max-h-0 transition-all duration-300 ease-in-out">
        <p class="px-6 pb-6 text-sm text-zinc-400 font-narrow leading-relaxed">
          La historia se desarrolla en el estado ficticio de Leonida, que contiene no solo las icónicas calles de Vice City, sino también suburbios costeros, playas enormes, puertos industriales y la extensa región pantanosa salvaje, conformando el mapa más interactivo y dinámico de la saga.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* Transition trigger rotation */
  .faq-item.active .faq-trigger svg {
    transform: rotate(180deg);
    color: var(--color-pink-500);
  }
  
  .faq-item[data-border="1"].active .faq-trigger svg {
    color: var(--color-purple-500);
  }
  
  .faq-item[data-border="2"].active .faq-trigger svg {
    color: var(--color-orange-500);
  }

  .faq-item.active {
    border-color: rgba(236, 72, 153, 0.4);
    background-color: rgba(9, 9, 11, 0.7);
  }

  .faq-item.active:nth-child(2) {
    border-color: rgba(168, 85, 247, 0.4);
  }
  
  .faq-item.active:nth-child(3) {
    border-color: rgba(249, 115, 22, 0.4);
  }

  .faq-content {
    transition: max-height 0.3s ease-in-out;
  }
</style>

<script>
  const items = document.querySelectorAll(".faq-item");

  items.forEach((item, index) => {
    // Assign index data border just for distinct colored glows
    item.setAttribute("data-border", (index % 3).toString());

    const trigger = item.querySelector(".faq-trigger");
    const content = item.querySelector(".faq-content") as HTMLElement;

    trigger?.addEventListener("click", () => {
      const isActive = item.classList.contains("active");

      // Close all items first for accordion behavior
      items.forEach(el => {
        el.classList.remove("active");
        const elContent = el.querySelector(".faq-content") as HTMLElement;
        if (elContent) elContent.style.maxHeight = "0";
      });

      if (!isActive) {
        item.classList.add("active");
        if (content) {
          // Set to actual scrollHeight to animate correctly
          content.style.maxHeight = `${content.scrollHeight}px`;
        }
      }
    });
  });
</script>
