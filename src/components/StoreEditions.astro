---
---

<!-- Section: Pre-order Editions Store -->
<section id="ediciones" class="scroll-mt-28 space-y-16 py-12 relative z-10">
  <div class="text-center max-w-2xl mx-auto space-y-4 reveal-on-scroll">
    <span class="text-xs font-bold tracking-widest text-orange-500 uppercase bg-orange-500/10 px-3 py-1 rounded-full border border-orange-500/20">
      Tienda Oficial
    </span>
    <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight">ELIGE TU EDICIÓN</h2>
    <p class="text-zinc-400 font-narrow text-base md:text-lg">
      Reserva ahora y asegúrate de recibir contenido exclusivo de preventa y acceso anticipado al juego.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto reveal-section items-stretch">
    
    <!-- Edition 1: Standard -->
    <div class="reveal-item flex flex-col justify-between border border-zinc-800 bg-zinc-950/40 backdrop-blur-md rounded-3xl p-8 hover:border-zinc-700 transition-all duration-300 relative group">
      <div class="space-y-6">
        <div class="flex justify-between items-center">
          <span class="text-[10px] font-bold uppercase tracking-wider text-zinc-500 bg-zinc-900 px-2.5 py-1 rounded-full border border-zinc-800/60">Básico</span>
        </div>
        <div class="space-y-2">
          <h3 class="text-2xl font-extrabold tracking-wide text-white">EDICIÓN ESTÁNDAR</h3>
          <p class="text-xs text-zinc-400 font-narrow">Ideal para disfrutar de la campaña principal completa.</p>
        </div>
        <div class="py-2">
          <span class="text-4xl font-black font-mono text-white">$69.99</span>
          <span class="text-xs text-zinc-500 font-bold ml-1">USD</span>
        </div>
        <div class="border-t border-zinc-900 pt-6">
          <ul class="space-y-4 text-xs text-zinc-300 font-narrow">
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span>Juego Base GTA VI completo</span>
            </li>
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span>Pack de dinero GTA$ (Preventa)</span>
            </li>
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span>Tema de perfil exclusivo</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="pt-8">
        <button class="w-full bg-zinc-900 hover:bg-zinc-800 text-white font-bold py-3.5 rounded-full border border-zinc-800 hover:border-zinc-700 transition-colors text-xs tracking-wider uppercase cursor-pointer">
          Pre-ordenar
        </button>
      </div>
    </div>

    <!-- Edition 2: Deluxe (Highlighted) -->
    <div class="reveal-item flex flex-col justify-between border-2 border-pink-500 bg-zinc-950/60 backdrop-blur-md rounded-3xl p-8 transition-all duration-300 relative group scale-102 shadow-[0_0_30px_rgba(236,72,153,0.1)] hover:shadow-[0_0_40px_rgba(236,72,153,0.2)]">
      <!-- Glow decoration -->
      <div class="absolute -top-10 -left-10 size-32 rounded-full bg-pink-500/10 blur-2xl pointer-events-none"></div>
      
      <div class="space-y-6">
        <div class="flex justify-between items-center">
          <span class="text-[10px] font-bold uppercase tracking-wider text-pink-400 bg-pink-500/10 px-2.5 py-1 rounded-full border border-pink-500/20">Recomendado</span>
          <span class="text-[9px] font-bold uppercase tracking-wider text-white bg-gradient-to-r from-pink-500 to-orange-500 px-2.5 py-1 rounded-full border-0">Popular</span>
        </div>
        <div class="space-y-2">
          <h3 class="text-2xl font-extrabold tracking-wide text-white bg-gradient-to-r from-pink-500 to-orange-400 bg-clip-text text-transparent">EDICIÓN DELUXE</h3>
          <p class="text-xs text-zinc-400 font-narrow font-semibold">Consigue acceso anticipado de 3 días y extras digitales.</p>
        </div>
        <div class="py-2">
          <span class="text-4xl font-black font-mono text-white">$89.99</span>
          <span class="text-xs text-zinc-500 font-bold ml-1">USD</span>
        </div>
        <div class="border-t border-zinc-900 pt-6">
          <ul class="space-y-4 text-xs text-zinc-300 font-narrow">
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-pink-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-semibold text-white">Acceso Anticipado de 3 días</span>
            </li>
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-pink-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span>Pack de inicio de Leonida (GTA Online)</span>
            </li>
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-pink-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span>Skins Cheetah exclusivas para Jason y Lucia</span>
            </li>
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-pink-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span>Todo el contenido Estándar incluido</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="pt-8">
        <button class="w-full relative group px-6 py-4 rounded-full font-bold text-xs tracking-wider uppercase transition-all duration-300 cursor-pointer overflow-hidden border-0 bg-transparent">
          <div class="absolute inset-0 bg-gradient-to-r from-pink-500 to-orange-500 rounded-full group-hover:scale-102 transition-transform duration-300"></div>
          <span class="relative text-white">Pre-ordenar</span>
        </button>
      </div>
    </div>

    <!-- Edition 3: Collector's -->
    <div class="reveal-item flex flex-col justify-between border border-zinc-800 bg-zinc-950/40 backdrop-blur-md rounded-3xl p-8 hover:border-orange-500/20 transition-all duration-300 relative group">
      <!-- Glow decoration -->
      <div class="absolute -top-10 -right-10 size-32 rounded-full bg-orange-500/5 blur-2xl pointer-events-none"></div>

      <div class="space-y-6">
        <div class="flex justify-between items-center">
          <span class="text-[10px] font-bold uppercase tracking-wider text-orange-400 bg-orange-500/10 px-2.5 py-1 rounded-full border border-orange-500/20">Edición Limitada</span>
        </div>
        <div class="space-y-2">
          <h3 class="text-2xl font-extrabold tracking-wide text-white">EDICIÓN COLECCIÓN</h3>
          <p class="text-xs text-zinc-400 font-narrow font-semibold">El lote definitivo para los fanáticos físicos y digitales.</p>
        </div>
        <div class="py-2">
          <span class="text-4xl font-black font-mono text-white">$149.99</span>
          <span class="text-xs text-zinc-500 font-bold ml-1">USD</span>
        </div>
        <div class="border-t border-zinc-900 pt-6">
          <ul class="space-y-4 text-xs text-zinc-300 font-narrow">
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span class="font-semibold text-white">Estuche Metálico (Steelbook físico)</span>
            </li>
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span>Mapa Físico de Leonida a doble cara</span>
            </li>
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span>Gorra oficial y parches de Lucía & Jason</span>
            </li>
            <li class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="size-4 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3.5" d="M5 13l4 4L19 7" />
              </svg>
              <span>Contenido digital extra (Misiones de atraco)</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="pt-8">
        <button class="w-full bg-zinc-900 hover:bg-zinc-800 text-white font-bold py-3.5 rounded-full border border-orange-500/20 hover:border-orange-500/50 transition-colors text-xs tracking-wider uppercase cursor-pointer">
          Pre-ordenar
        </button>
      </div>
    </div>

  </div>
</section>
