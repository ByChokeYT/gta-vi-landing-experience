---
import LuciaPortrait from "@/assets/lucia-portrait.png"
import JasonPortrait from "@/assets/jason-portrait.png"
---

<!-- Section: Protagonists -->
<section id="personajes" class="scroll-mt-28 space-y-12 py-12 relative z-10" data-active="lucia">
  <!-- Glowing backdrops that transition based on active character -->
  <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full blur-[140px] pointer-events-none transition-all duration-700 bg-pink-600/10 active-glow"></div>

  <div class="text-center max-w-2xl mx-auto space-y-4 reveal-on-scroll">
    <span class="text-xs font-bold tracking-widest text-orange-500 uppercase bg-orange-500/10 px-3 py-1 rounded-full border border-orange-500/20">
      Personajes Principales
    </span>
    <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight">DOS HISTORIAS, UN DESTINO</h2>
    <p class="text-zinc-400 font-narrow text-base md:text-lg">
      Una historia de confianza, traición y crimen en el corazón de Leonida. Controla a la primera protagonista femenina de la franquicia y a su compañero de crímenes.
    </p>
  </div>

  <!-- Switcher Toggle with Sliding Background -->
  <div class="relative flex justify-between items-center w-[260px] mx-auto p-1 bg-zinc-950/80 border border-zinc-800 rounded-full select-none z-20 reveal-on-scroll">
    <!-- Active Slider Indicator -->
    <div
      id="character-slider-bg"
      class="absolute top-1 bottom-1 left-1 w-[calc(50%-2px)] bg-gradient-to-r from-pink-500 to-pink-600 rounded-full transition-all duration-300 transform translate-x-0"
    ></div>
    
    <button
      id="switch-lucia"
      class="character-switch-btn relative z-10 flex-1 py-2 text-xs font-extrabold uppercase tracking-widest text-white transition-colors cursor-pointer text-center"
      data-character="lucia"
    >
      Lucia
    </button>
    <button
      id="switch-jason"
      class="character-switch-btn relative z-10 flex-1 py-2 text-xs font-extrabold uppercase tracking-widest text-zinc-400 hover:text-white transition-colors cursor-pointer text-center"
      data-character="jason"
    >
      Jason
    </button>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 reveal-section">
    <!-- Lucia Card -->
    <div 
      id="lucia-card" 
      class="protagonist-card group relative overflow-hidden rounded-3xl border border-zinc-800 bg-zinc-950/60 backdrop-blur-md hover:border-pink-500/30 transition-all duration-500 flex flex-col reveal-item cursor-default z-20"
    >
      <!-- Glare Effect Overlay -->
      <div class="glare absolute inset-0 pointer-events-none opacity-0 transition-opacity duration-300 z-30"></div>
      
      <!-- Pink Card Glow -->
      <div class="absolute -top-40 -left-40 size-80 rounded-full bg-pink-600/5 blur-3xl pointer-events-none group-hover:bg-pink-600/15 transition-all duration-700"></div>
      
      <div class="aspect-[16/10] w-full overflow-hidden relative">
        <img src={LuciaPortrait.src} alt="Lucia" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700" />
        <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/10 to-transparent"></div>
        <div class="absolute bottom-6 left-8">
          <span class="text-xs font-bold uppercase tracking-[4px] text-pink-500">Protagonista</span>
          <h3 class="text-3xl md:text-4xl font-extrabold text-white tracking-wide mt-1">LUCIA</h3>
        </div>
      </div>
      
      <div class="p-8 flex-grow space-y-4 relative z-20">
        <p class="text-zinc-300 font-narrow leading-relaxed">
          Decidida, astuta y leal. Lucia es una superviviente nata que regresa a las calles tras un paso por prisión. Junto a Jason, se embarca en una espiral criminal buscando el golpe definitivo para cambiar sus vidas en Leonida.
        </p>
        <div class="border-t border-zinc-800/60 pt-4 flex gap-4 text-xs font-semibold tracking-wider text-zinc-400">
          <div><span class="text-pink-500">Habilidades:</span> Planificación, Combate</div>
          <div><span class="text-pink-500">Origen:</span> Vice City</div>
        </div>
      </div>
    </div>
    
    <!-- Jason Card -->
    <div 
      id="jason-card" 
      class="protagonist-card group relative overflow-hidden rounded-3xl border border-zinc-800 bg-zinc-950/60 backdrop-blur-md hover:border-orange-500/30 transition-all duration-500 flex flex-col reveal-item cursor-default opacity-30 scale-98 pointer-events-none blur-[1px] hidden-mobile"
    >
      <!-- Glare Effect Overlay -->
      <div class="glare absolute inset-0 pointer-events-none opacity-0 transition-opacity duration-300 z-30"></div>
      
      <!-- Orange Card Glow -->
      <div class="absolute -top-40 -right-40 size-80 rounded-full bg-orange-600/5 blur-3xl pointer-events-none group-hover:bg-orange-600/15 transition-all duration-700"></div>
      
      <div class="aspect-[16/10] w-full overflow-hidden relative">
        <img src={JasonPortrait.src} alt="Jason" class="w-full h-full object-cover group-hover:scale-102 transition-transform duration-700" />
        <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/10 to-transparent"></div>
        <div class="absolute bottom-6 left-8">
          <span class="text-xs font-bold uppercase tracking-[4px] text-orange-500">Coprotagonista</span>
          <h3 class="text-3xl md:text-4xl font-extrabold text-white tracking-wide mt-1">JASON</h3>
        </div>
      </div>
      
      <div class="p-8 flex-grow space-y-4 relative z-20">
        <p class="text-zinc-300 font-narrow leading-relaxed">
          Silencioso pero letal, leal y comprometido. Jason es un personaje misterioso arrastrado al círculo íntimo de Lucia. Su relación pondrá a prueba no solo su capacidad para delinquir, sino también su confianza mutua en situaciones extremas.
        </p>
        <div class="border-t border-zinc-800/60 pt-4 flex gap-4 text-xs font-semibold tracking-wider text-zinc-400">
          <div><span class="text-orange-500">Habilidades:</span> Conducción, Armas</div>
          <div><span class="text-orange-500">Origen:</span> Leonida</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .protagonist-card {
    transform-style: preserve-3d;
    will-change: transform, opacity, scale, filter;
    transition: transform 0.2s ease-out, border-color 0.4s ease, box-shadow 0.4s ease, opacity 0.5s ease, filter 0.5s ease, scale 0.5s ease;
  }
  
  .protagonist-card:hover:not(.pointer-events-none) {
    box-shadow: 0 10px 35px -10px rgba(236, 72, 153, 0.1);
  }

  /* Active glow selector colors */
  [data-active="lucia"] .active-glow {
    background-color: rgba(236, 72, 153, 0.08);
  }
  [data-active="jason"] .active-glow {
    background-color: rgba(249, 115, 22, 0.08);
  }

  @media (max-w: 768px) {
    .hidden-mobile {
      display: none !important;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll(".protagonist-card");
  
  // Card 3D tilt effects
  cards.forEach(card => {
    const glare = card.querySelector(".glare") as HTMLElement;
    
    card.addEventListener("mousemove", (e: any) => {
      if (card.classList.contains("pointer-events-none")) return;

      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      
      const rotateX = ((centerY - y) / centerY) * 5; 
      const rotateY = ((x - centerX) / centerX) * 5;
      
      (card as HTMLElement).style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.01, 1.01, 1.01)`;
      
      const glareX = (x / rect.width) * 100;
      const glareY = (y / rect.height) * 100;
      if (glare) {
        glare.style.background = `radial-gradient(circle at ${glareX}% ${glareY}%, rgba(255, 255, 255, 0.07) 0%, transparent 65%)`;
        glare.style.opacity = "1";
      }
    });
    
    card.addEventListener("mouseleave", () => {
      (card as HTMLElement).style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1, 1, 1)`;
      if (glare) {
        glare.style.opacity = "0";
      }
    });
  });

  // Dynamic Switcher Logic
  const switchLucia = document.getElementById("switch-lucia");
  const switchJason = document.getElementById("switch-jason");
  const sliderBg = document.getElementById("character-slider-bg");
  const switchBtns = document.querySelectorAll(".character-switch-btn");
  
  const luciaCard = document.getElementById("lucia-card");
  const jasonCard = document.getElementById("jason-card");
  const section = document.getElementById("personajes");
  
  function selectCharacter(char: string) {
    if (char === "lucia") {
      switchLucia?.classList.add("text-white");
      switchLucia?.classList.remove("text-zinc-400");
      switchJason?.classList.add("text-zinc-400");
      switchJason?.classList.remove("text-white");
      
      sliderBg?.classList.remove("translate-x-[calc(100%-2px)]", "from-orange-500", "to-orange-600");
      sliderBg?.classList.add("translate-x-0", "from-pink-500", "to-pink-600");
      
      luciaCard?.classList.remove("opacity-30", "scale-98", "pointer-events-none", "blur-[1px]", "hidden-mobile");
      luciaCard?.classList.add("z-20");
      
      jasonCard?.classList.add("opacity-30", "scale-98", "pointer-events-none", "blur-[1px]", "hidden-mobile");
      jasonCard?.classList.remove("z-20");
      
      section?.setAttribute("data-active", "lucia");
    } else {
      switchJason?.classList.add("text-white");
      switchJason?.classList.remove("text-zinc-400");
      switchLucia?.classList.add("text-zinc-400");
      switchLucia?.classList.remove("text-white");
      
      sliderBg?.classList.remove("translate-x-0", "from-pink-500", "to-pink-600");
      sliderBg?.classList.add("translate-x-[calc(100%-2px)]", "from-orange-500", "to-orange-600");
      
      jasonCard?.classList.remove("opacity-30", "scale-98", "pointer-events-none", "blur-[1px]", "hidden-mobile");
      jasonCard?.classList.add("z-20");
      
      luciaCard?.classList.add("opacity-30", "scale-98", "pointer-events-none", "blur-[1px]", "hidden-mobile");
      luciaCard?.classList.remove("z-20");
      
      section?.setAttribute("data-active", "jason");
    }
  }
  
  switchBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      const char = btn.getAttribute("data-character") || "lucia";
      selectCharacter(char);
    });
  });
</script>
