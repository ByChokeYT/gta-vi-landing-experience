---
import ViceCityScenery from "@/assets/vice-city-scenery.png"
import ViceCityNight from "@/assets/vice-city-night.png"
import HeroKeyBackground from "@/assets/hero-key-background.webp"
---

<!-- Section: Leonida -->
<section id="leonida" class="scroll-mt-28 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center py-12 relative z-10">
  
  <div class="space-y-8 reveal-on-scroll">
    <div class="space-y-4">
      <span class="text-xs font-bold tracking-widest text-pink-500 uppercase bg-pink-500/10 px-3 py-1 rounded-full border border-pink-500/20">
        El Estado de Leonida
      </span>
      <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight bg-gradient-to-r from-pink-500 via-purple-500 to-orange-500 bg-clip-text text-transparent">
        VICE CITY ESTÁ DE VUELTA
      </h2>
      <p class="text-lg md:text-xl text-zinc-300 font-narrow leading-relaxed">
        Grand Theft Auto VI se dirige al estado de Leonida, hogar de las calles bañadas en neón de Vice City y la región más grande, diversa y realista jamás creada para la franquicia.
      </p>
    </div>

    <!-- Interactive Travel Guide Tabs Selector -->
    <div class="space-y-3">
      <h3 class="text-xs font-bold uppercase tracking-[3px] text-zinc-500">Explorar Ubicaciones</h3>
      <div class="flex flex-col sm:flex-row gap-3">
        <button
          class="location-tab active group flex items-center gap-3 px-5 py-3.5 rounded-2xl border border-zinc-800 bg-zinc-950/40 hover:bg-zinc-900/40 hover:border-pink-500/30 transition-all cursor-pointer text-left w-full sm:w-auto"
          data-tab="0"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-pink-500 group-[.active]:text-white transition-colors shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 8c0-2.76-2.24-5-5-5S3 5.24 3 8h10z" />
            <path d="M13 7.14A5.82 5.82 0 0 1 16.5 6c2.76 0 5 2.24 5 5h-10c0-1.32-.47-2.5-1.32-3.41L13 7.14z" />
            <path d="M5.8 15.5c.34-1.22.84-2.85 1.2-3.5" />
            <path d="M18.2 15.5c-.34-1.22-.84-2.85-1.2-3.5" />
            <path d="M8 22h8" />
            <path d="M12 12v10" />
          </svg>
          <span class="text-xs font-bold tracking-wider uppercase text-zinc-400 group-[.active]:text-white transition-colors">Playas y Avenidas</span>
        </button>
        <button
          class="location-tab group flex items-center gap-3 px-5 py-3.5 rounded-2xl border border-zinc-800 bg-zinc-950/40 hover:bg-zinc-900/40 hover:border-purple-500/30 transition-all cursor-pointer text-left w-full sm:w-auto"
          data-tab="1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-purple-400 group-[.active]:text-white transition-colors shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
            <path d="M19 3v4" />
            <path d="M21 5h-4" />
          </svg>
          <span class="text-xs font-bold tracking-wider uppercase text-zinc-400 group-[.active]:text-white transition-colors">Vida Nocturna</span>
        </button>
        <button
          class="location-tab group flex items-center gap-3 px-5 py-3.5 rounded-2xl border border-zinc-800 bg-zinc-950/40 hover:bg-zinc-900/40 hover:border-orange-500/30 transition-all cursor-pointer text-left w-full sm:w-auto"
          data-tab="2"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5 text-orange-500 group-[.active]:text-white transition-colors shrink-0" viewBox="0 0 122.88 123.03" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd">
            <path d="M31.83,39.82c15.66-3.09,28.2-12.25,40.71-24.57l8.24-7.91c5.15-4.94,6.97-7.81,14.9-7.28 c6.34,0.43,12.03,3.11,13.51,9.84c0.35,1.59,0.34,3.32-0.1,5.21c-0.58,2.48-2.07,5.5-3.84,8.19c0.99,2.69,1.78,5.39,2.18,8.08 c-1.97-0.2-4.03-2.08-6.05-3.26c-0.11,0.11-0.22,0.21-0.33,0.31c-2.12,1.97-4.56,3.45-7.33,4.42c-0.19,0.17-0.39,0.35-0.58,0.52 c0.72,2.84,1.24,5.67,1.35,8.44c-1.97-0.42-3.84-2.57-5.76-3.95c-1.56,1.75-3.12,3.66-4.66,5.7c1.34,2.84,2.46,5.7,3.14,8.59 c-2.23-0.04-4.73-2.06-7.1-3.09l0.13-0.2c-1.82,1.99-4.56,4.45-7.85,6.77c0.22,2.42,0.29,4.79,0.04,7.08 c-1.67-0.62-3.04-2.76-4.54-4.22c-1.14,0.65-2.32,1.26-3.52,1.82c-1.12,0.52-2.11,0.99-3,1.43c-0.08,2.95-0.35,5.83-1,8.55 c-1.78-0.93-2.99-3.5-4.45-5.36c-1.83,1.38-3.09,2.86-4.93,5.19c0.84,2.22,1.52,4.44,1.86,6.66c-1.63-0.15-3.34-1.72-5.01-2.66 c-0.3,0.38-0.62,0.77-0.95,1.18c-3.69,4.53-8.11,7.5-12.16,9.3l-7.48,3.15c5.93,2.09,13.32,0.92,22.45-4.14 c4.47-2.64,9.23-4.66,14.28-6.1c-0.83-2.23-2.72-3.97-2.61-6.03c2.59,0.8,5.23,3.3,7.74,4.78c5.21-1.05,10.7-1.54,16.43-1.52 l1.09-0.62c-0.34,0.18-0.69,0.36-1.03,0.55c-0.81-2.29-4.65-7.58-4.53-9.67c2.33-0.35,7.52,5.06,10.11,6.52 c-0.14,0.09-0.27,0.18-0.41,0.28l6.42-3.63c-0.96-2.3-4.08-5.87-3.97-7.88c2.65,0.82,6.85,3.32,9.45,4.78l10.06-5.68 c6.54-2.32,11.64,0.91,9.76,9.01c-1.54,6.62-5.12,9.22-10.99,12.4c-5.06,2.74-11.7,5.3-19.46,7.74 c-10.02,3.53-16.31,9.41-22.42,15.61C56,118.02,42.43,129.39,21.67,118.99c-6.33-3.17-11.31-8.08-14.9-13.91 c-5.41-8.8-7.63-19.7-6.48-29.96C1,68.82,3.12,63.3,6.76,58.62c-0.53-4.59-0.31-8.57,0.74-11.85C10.79,36.5,23.19,33.5,31.83,39.82 L31.83,39.82z M96.1,6.39c2.29,0.77,3.82,2.73,4.5,5.98l-8.1-0.28c-0.73-0.32-1.23-0.85-1.5-1.57c-0.31-0.81-0.42-1.43-0.37-1.94 C90.9,6.03,94.04,5.69,96.1,6.39L96.1,6.39z M16.34,52.1c-0.14,1.72,0.97,5.72,2.76,6.34c0.59,0.2,1.29,0.13,2.11-0.25l2.87-2.36 l0.03-0.04l-3.61-5.07c1.7-0.68,4.15-0.36,7.03,0.54l1.86-2.46C25.3,43.12,16.84,46.03,16.34,52.1L16.34,52.1z M64.61,77.36 c0.68-0.19,1.36-0.36,2.04-0.52C65.87,76.93,65.41,76.99,64.61,77.36L64.61,77.36z M108.74,61.57c1.95-1.04,3.77-2.15,5.46-3.32 c-2.59-1.45-5.21-2.71-7.89-3.54C106.2,56.81,107.93,59.29,108.74,61.57L108.74,61.57z"/>
          </svg>
          <span class="text-xs font-bold tracking-wider uppercase text-zinc-400 group-[.active]:text-white transition-colors">Pantanos y Periferia</span>
        </button>
      </div>
    </div>

    <div class="pt-4">
      <a
        href="#personajes"
        class="inline-flex items-center gap-2 text-pink-400 hover:text-pink-300 font-semibold group transition-colors"
      >
        Conoce a Lucía y Jason
        <svg xmlns="http://www.w3.org/2000/svg" class="size-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </div>
  
  <div class="relative reveal-on-scroll h-[440px] md:h-[480px]">
    <!-- Glow effect -->
    <div class="absolute -inset-1 rounded-3xl bg-gradient-to-r from-pink-500 to-orange-500 opacity-20 blur-xl"></div>
    
    <!-- Location Pane Container (Absolute stacks for cross-fade) -->
    <div class="relative w-full h-full rounded-3xl border border-zinc-800 bg-zinc-950/80 backdrop-blur overflow-hidden">
      
      <!-- Pane 0: Ocean Drive -->
      <div class="location-pane active absolute inset-0 p-8 md:p-10 flex flex-col space-y-6 transition-all duration-500 opacity-100 pointer-events-auto">
        <div class="h-60 rounded-2xl overflow-hidden relative group">
          <img src={ViceCityScenery.src} alt="Vice City Sunset" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
          <span class="absolute bottom-4 left-4 text-sm font-bold tracking-wider text-white uppercase drop-shadow">Ocean Drive</span>
        </div>
        <div class="space-y-4">
          <h3 class="text-xl md:text-2xl font-bold">Ocean Drive y las Playas</h3>
          <p class="text-sm md:text-base text-zinc-400 font-narrow leading-relaxed">
            Las avenidas bordeadas de palmeras, la arena dorada y el inconfundible atardecer de Vice City están de vuelta, más vivos y concurridos que nunca.
          </p>
        </div>
      </div>

      <!-- Pane 1: Vice City Nights -->
      <div class="location-pane absolute inset-0 p-8 md:p-10 flex flex-col space-y-6 transition-all duration-500 opacity-0 pointer-events-none">
        <div class="h-60 rounded-2xl overflow-hidden relative group">
          <img src={ViceCityNight.src} alt="Vice City Nights" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
          <span class="absolute bottom-4 left-4 text-sm font-bold tracking-wider text-white uppercase drop-shadow">Sunset Strip</span>
        </div>
        <div class="space-y-4">
          <h3 class="text-xl md:text-2xl font-bold">El Brillo de la Noche</h3>
          <p class="text-sm md:text-base text-zinc-400 font-narrow leading-relaxed">
            Cuando el sol se oculta, los rascacielos se tiñen de luces de neón y los clubes exclusivos abren sus puertas. La noche es propicia para los negocios de Jason y Lucía.
          </p>
        </div>
      </div>

      <!-- Pane 2: Swamps & Wilds -->
      <div class="location-pane absolute inset-0 p-8 md:p-10 flex flex-col space-y-6 transition-all duration-500 opacity-0 pointer-events-none">
        <div class="h-60 rounded-2xl overflow-hidden relative group">
          <img src={HeroKeyBackground.src} alt="Leonida Swamps" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/20 to-transparent"></div>
          <span class="absolute bottom-4 left-4 text-sm font-bold tracking-wider text-white uppercase drop-shadow">Grasslands Swamp</span>
        </div>
        <div class="space-y-4">
          <h3 class="text-xl md:text-2xl font-bold">Los Pantanos y Periferia</h3>
          <p class="text-sm md:text-base text-zinc-400 font-narrow leading-relaxed">
            El estado de Leonida se extiende más allá de la ciudad. Explora los densos pantanos salvajes infestados de caimanes, los pequeños pueblos periféricos y las autopistas solitarias.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Tab active states */
  .location-tab.active {
    background-color: rgba(39, 39, 42, 0.6);
    border-color: var(--color-pink-500);
    box-shadow: 0 0 15px rgba(236, 72, 153, 0.15);
  }
  
  .location-tab[data-tab="1"].active {
    border-color: var(--color-purple-500);
    box-shadow: 0 0 15px rgba(168, 85, 247, 0.15);
  }
  
  .location-tab[data-tab="2"].active {
    border-color: var(--color-orange-500);
    box-shadow: 0 0 15px rgba(249, 115, 22, 0.15);
  }

  /* Pane transitions */
  .location-pane.active {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  
  .location-pane:not(.active) {
    opacity: 0;
    pointer-events: none;
    transform: translateY(15px);
  }
</style>

<script>
  const tabs = document.querySelectorAll(".location-tab");
  const panes = document.querySelectorAll(".location-pane");

  tabs.forEach(tab => {
    tab.addEventListener("click", () => {
      // Remove active state from all tabs
      tabs.forEach(t => t.classList.remove("active"));
      // Add active state to clicked tab
      tab.classList.add("active");

      // Hide all panes
      const targetIndex = tab.getAttribute("data-tab");
      panes.forEach((pane, index) => {
        if (index.toString() === targetIndex) {
          pane.classList.add("active");
        } else {
          pane.classList.remove("active");
        }
      });
    });
  });
</script>
