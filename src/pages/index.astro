---
import Layout from "@/layouts/Layout.astro"
import Navbar from "@/components/Navbar.astro"
import HeroMask from "@/components/HeroMask.astro"
import Leonida from "@/components/Leonida.astro"
import Features from "@/components/Features.astro"
import Protagonists from "@/components/Protagonists.astro"
import RadioPlayer from "@/components/RadioPlayer.astro"
import SocialFeed from "@/components/SocialFeed.astro"
import Gallery from "@/components/Gallery.astro"
import StoreEditions from "@/components/StoreEditions.astro"
import FAQ from "@/components/FAQ.astro"
import Countdown from "@/components/Countdown.astro"
import TrailerModal from "@/components/TrailerModal.astro"
import Footer from "@/components/Footer.astro"
---

<Layout>
  <Navbar />
  <HeroMask />

  <!-- Main Website Content (Revealed below the fold) -->
  <main id="main-content" class="relative w-full z-30 pt-[100vh] pb-24 px-6 md:px-12 max-w-7xl mx-auto space-y-48">
    <Leonida />
    <Features />
    <Protagonists />
    <RadioPlayer />
    <SocialFeed />
    <Gallery />
    <StoreEditions />
    <FAQ />
    <Countdown />
    <Footer />
  </main>

  <TrailerModal />
</Layout>

<script>
  import { gsap } from "gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  gsap.registerPlugin(ScrollTrigger)

  // Disable GSAP's scroll normalization to prevent mouse wheel from being captured
  ScrollTrigger.normalizeScroll(false)

  // 1. Initial Hero Mask Animation Timeline (Original exact behavior)
  const tl = gsap.timeline({
    ease: "power2.out",
    scrollTrigger: {
      trigger: "body",
      start: "top top",
      end: () => window.innerHeight, // Scrub over exactly 1 screen height (100vh)
      scrub: 0.5,
    },
  })

  // Scrub actions (exact original zoom-mask behavior)
  tl.to("#keep-scrolling", { opacity: 0, duration: 0.1 }, 0)
    .to("#hero-key", { duration: 1, scale: 1 }, 0)
    .to("#hero-key-logo", { opacity: 0 }, 0)
    .to("#hero-footer", { opacity: 0 }, 0)
    .to("#hero-play-button", { opacity: 0 }, 0)
    .to(
      "#logo-mask",
      {
        maskSize: "clamp(20vh, 25%, 30vh)",
      },
      0.15
    )
    .to(
      "#hero-key",
      {
        opacity: 0,
        duration: 0.2,
      },
      0.4
    )
    .to(
      "#logo-mask",
      {
        opacity: 0,
        pointerEvents: "none",
        duration: 0.3,
      },
      0.4
    )
    .to(
      "#hero-ui",
      {
        opacity: 0,
        pointerEvents: "none",
        duration: 0.2,
      },
      0.4
    )
    // Reveal top navigation menu
    .to(
      "#main-nav",
      {
        opacity: 1,
        pointerEvents: "auto",
        duration: 0.2,
      },
      0.5
    )

  // 2. Scroll Reveal Animations (Single & Staggered) for sections below the fold
  const singleReveals = document.querySelectorAll(".reveal-on-scroll")
  singleReveals.forEach((el) => {
    gsap.fromTo(
      el,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: el,
          start: "top 85%",
          toggleActions: "play none none none",
        },
      }
    )
  })

  const revealSections = document.querySelectorAll(".reveal-section")
  revealSections.forEach((sec) => {
    const items = sec.querySelectorAll(".reveal-item")
    gsap.fromTo(
      items,
      { opacity: 0, y: 50 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.15,
        ease: "power3.out",
        scrollTrigger: {
          trigger: sec,
          start: "top 80%",
          toggleActions: "play none none none",
        },
      }
    )
  })
</script>
