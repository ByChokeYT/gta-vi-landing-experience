---
import Layout from "@/layouts/Layout.astro"
import Navbar from "@/components/Navbar.astro"
import HeroMask from "@/components/HeroMask.astro"
import Leonida from "@/components/Leonida.astro"
import Features from "@/components/Features.astro"
import Protagonists from "@/components/Protagonists.astro"
import RadioPlayer from "@/components/RadioPlayer.astro"
import SocialFeed from "@/components/SocialFeed.astro"
import Gallery from "@/components/Gallery.astro"
import FAQ from "@/components/FAQ.astro"
import Countdown from "@/components/Countdown.astro"
import TrailerModal from "@/components/TrailerModal.astro"
import Footer from "@/components/Footer.astro"
---

<Layout>
  <Navbar />
  <HeroMask />

  <!-- Main Website Content (Revealed below the fold) -->
  <main id="main-content" class="relative w-full z-30 pt-[100vh] pb-24 px-6 md:px-12 max-w-7xl mx-auto space-y-48">
    <Leonida />
    <Features />
    <Protagonists />
    <RadioPlayer />
    <SocialFeed />
    <Gallery />
    <FAQ />
    <Countdown />
    <Footer />
  </main>

  <TrailerModal />
</Layout>

<script>
  import { gsap } from "gsap"
  import { ScrollTrigger } from "gsap/ScrollTrigger"

  gsap.registerPlugin(ScrollTrigger)

  // 1. Initial Hero Mask Animation Timeline (Original exact behavior)
  const tl = gsap.timeline({
    ease: "power2.out",
    scrollTrigger: {
      trigger: "body",
      start: "top top",
      end: "100% top", // Scrub over 1 screen height
      scrub: 1,
    },
  })

  // Scrub actions (exact original zoom-mask behavior)
  tl.to("#keep-scrolling", { opacity: 0, duration: 0.1 }, 0)
    .to("#hero-key", { duration: 1, scale: 1 }, 0)
    .to("#hero-key-logo", { opacity: 0 }, 0)
    .to("#hero-footer", { opacity: 0 }, 0)
    .to("#hero-play-button", { opacity: 0 }, 0)
    .to(
      "#logo-mask",
      {
        maskSize: "clamp(20vh, 25%, 30vh)",
      },
      0.15
    )
    .to(
      "#hero-key",
      {
        opacity: 0,
        duration: 0.2,
      },
      0.4
    )
    .to(
      "#logo-mask",
      {
        opacity: 0,
        pointerEvents: "none",
        duration: 0.3,
      },
      0.4
    )
    .to(
      "#hero-ui",
      {
        opacity: 0,
        pointerEvents: "none",
        duration: 0.2,
      },
      0.4
    )
    // Reveal top navigation menu
    .to(
      "#main-nav",
      {
        opacity: 1,
        pointerEvents: "auto",
        duration: 0.2,
      },
      0.5
    )

  // 2. Scroll Reveal Animations (Single & Staggered) for sections below the fold
  const singleReveals = document.querySelectorAll(".reveal-on-scroll")
  singleReveals.forEach((el) => {
    gsap.fromTo(
      el,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: el,
          start: "top 85%",
          toggleActions: "play none none none",
        },
      }
    )
  })

  const revealSections = document.querySelectorAll(".reveal-section")
  revealSections.forEach((sec) => {
    const items = sec.querySelectorAll(".reveal-item")
    gsap.fromTo(
      items,
      { opacity: 0, y: 50 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.15,
        ease: "power3.out",
        scrollTrigger: {
          trigger: sec,
          start: "top 80%",
          toggleActions: "play none none none",
        },
      }
    )
  })

  // 3. YouTube Trailer Video Modal Logic
  const playButton = document.getElementById("hero-play-button")
  const footerButton = document.getElementById("hero-footer")
  const videoModal = document.getElementById("video-modal")
  const closeModal = document.getElementById("close-modal")
  const videoContainer = document.getElementById("video-container")

  function openVideo() {
    if (videoContainer && videoModal) {
      videoContainer.innerHTML = `<iframe class="w-full h-full" src="https://www.youtube.com/embed/QdBZY2fkU-0?autoplay=1" title="Grand Theft Auto VI Trailer 1" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>`
      videoModal.classList.remove("opacity-0", "pointer-events-none")
      document.body.style.overflow = "hidden"
    }
  }

  function closeVideo() {
    if (videoContainer && videoModal) {
      videoContainer.innerHTML = ""
      videoModal.classList.add("opacity-0", "pointer-events-none")
      document.body.style.overflow = ""
    }
  }

  playButton?.addEventListener("click", openVideo)
  footerButton?.addEventListener("click", openVideo)
  closeModal?.addEventListener("click", closeVideo)
  videoModal?.addEventListener("click", (e) => {
    if (e.target === videoModal) {
      closeVideo()
    }
  })

  // 4. Lightbox Gallery Logic
  const galleryItems = document.querySelectorAll(".gallery-item")
  const lightbox = document.getElementById("lightbox")
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement
  const closeLightbox = document.getElementById("close-lightbox")

  galleryItems.forEach((item) => {
    item.addEventListener("click", () => {
      const src = item.getAttribute("data-src")
      if (src && lightboxImg && lightbox) {
        lightboxImg.src = src
        lightbox.classList.remove("opacity-0", "pointer-events-none")
        document.body.style.overflow = "hidden"
      }
    })
  })

  function closeLightboxFunc() {
    if (lightbox) {
      lightbox.classList.add("opacity-0", "pointer-events-none")
      document.body.style.overflow = ""
    }
  }

  closeLightbox?.addEventListener("click", closeLightboxFunc)
  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) {
      closeLightboxFunc()
    }
  })

  // 5. Release Countdown Timer Logic
  const targetDate = new Date("December 31, 2026 00:00:00").getTime()

  function updateCountdown() {
    const now = new Date().getTime()
    const difference = targetDate - now

    if (difference <= 0) {
      const countdownEl = document.querySelector(".font-mono")
      if (countdownEl) countdownEl.innerHTML = "<div class='col-span-4 text-2xl font-bold text-pink-500'>¡GTA VI ESTÁ AQUÍ!</div>"
      clearInterval(countdownInterval)
      return
    }

    const days = Math.floor(difference / (1000 * 60 * 60 * 24))
    const hours = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))
    const minutes = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60))
    const seconds = Math.floor((difference % (1000 * 60)) / 1000)

    const daysEl = document.getElementById("days")
    const hoursEl = document.getElementById("hours")
    const minutesEl = document.getElementById("minutes")
    const secondsEl = document.getElementById("seconds")

    if (daysEl) daysEl.innerText = days.toString().padStart(2, "0")
    if (hoursEl) hoursEl.innerText = hours.toString().padStart(2, "0")
    if (minutesEl) minutesEl.innerText = minutes.toString().padStart(2, "0")
    if (secondsEl) secondsEl.innerText = seconds.toString().padStart(2, "0")
  }

  updateCountdown()
  const countdownInterval = setInterval(updateCountdown, 1000)
</script>
