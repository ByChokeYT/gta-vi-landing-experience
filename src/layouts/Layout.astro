---
import KeepScrolling from "@/assets/keep-scrolling.svg"
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Primary Meta Tags -->
    <title>Grand Theft Auto VI - Landing Page Oficial de Tributo</title>
    <meta name="title" content="Grand Theft Auto VI - Landing Page Oficial de Tributo" />
    <meta name="description" content="Bienvenido al estado de Leonida y a las calles de Vice City. Explora los personajes, la música, la galería y prepárate para el lanzamiento de GTA VI." />
    <meta name="keywords" content="GTA VI, Grand Theft Auto VI, Vice City, Lucia, Jason, Rockstar Games, Leonida, GTA 6" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Grand Theft Auto VI - Landing Page Oficial de Tributo" />
    <meta property="og:description" content="Bienvenido al estado de Leonida y a las calles de Vice City. Explora los personajes, la música, la galería y prepárate para el lanzamiento de GTA VI." />
    <meta property="og:image" content="/favicon.svg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary" />
    <meta property="twitter:title" content="Grand Theft Auto VI - Landing Page Oficial de Tributo" />
    <meta property="twitter:description" content="Bienvenido al estado de Leonida y a las calles de Vice City. Explora los personajes, la música, la galería y prepárate para el lanzamiento de GTA VI." />
    <meta property="twitter:image" content="/favicon.svg" />
  </head>
  <body>
    <!-- Ambient Neon Lights Background -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute top-[15vh] -left-48 size-[500px] rounded-full bg-pink-500/8 blur-[130px] animate-ambient-float-1"></div>
      <div class="absolute top-[60vh] -right-48 size-[600px] rounded-full bg-orange-500/8 blur-[140px] animate-ambient-float-2"></div>
      <div class="absolute top-[40vh] left-1/3 size-[400px] rounded-full bg-purple-600/4 blur-[130px] animate-ambient-float-3"></div>
    </div>

    <slot />
    <KeepScrolling
      id="keep-scrolling"
      class="fixed bottom-3 right-0 left-0 mx-auto text-pink-300 drop-shadow-2xl animate-bounce-pulse"
    />
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  @theme {
    --font-sans: "GTA", system-ui, sans-serif;
    --font-narrow: "GTANarrow", system-ui, sans-serif;

    --animate-bounce-pulse: bounce-pulse 2s ease-in-out infinite;
    --animate-ambient-float-1: ambient-float-1 25s ease-in-out infinite;
    --animate-ambient-float-2: ambient-float-2 30s ease-in-out infinite;
    --animate-ambient-float-3: ambient-float-3 20s ease-in-out infinite;
  }

  @keyframes ambient-float-1 {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(40px, 80px) scale(1.1);
    }
  }

  @keyframes ambient-float-2 {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-80px, -40px) scale(1.15);
    }
  }

  @keyframes ambient-float-3 {
    0%, 100% {
      transform: translate(0, 0) scale(1.05);
    }
    50% {
      transform: translate(60px, -60px) scale(0.95);
    }
  }

  @keyframes bounce-pulse {
    0% {
      transform: translateY(0);
      scale: 0.8;
      opacity: 0.8;
    }

    50% {
      transform: translateY(-5px);
      opacity: 1;
      scale: 1;
    }

    100% {
      transform: translateY(0);
      scale: 0.8;
      opacity: 0.8;
    }
  }

  html,
  body {
    background: #09090b;
    overflow-x: hidden;
    overscroll-behavior: none;
    color: white;
    margin: 0;
    width: 100%;
    scroll-behavior: smooth;
  }

  /* Custom premium scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }
  ::-webkit-scrollbar-track {
    background: #09090b;
  }
  ::-webkit-scrollbar-thumb {
    background: #27272a;
    border-radius: 4px;
    border: 2px solid #09090b;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #ec4899;
  }

  /* Selection style */
  ::selection {
    background: #ec4899;
    color: white;
  }

  @font-face {
    font-family: GTA;
    src: url("/fonts/gta-regular.woff") format("woff");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: GTA;
    src: url("/fonts/gta-bold.woff") format("woff");
    font-weight: bold;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: GTA;
    src: url("/fonts/gta-semibold.woff") format("woff");
    font-weight: 600;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: GTANarrow;
    src: url("/fonts/gta-narrow.woff") format("woff");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }
</style>
